# Backend Environment Variables Example
# Copy this file to .env and fill in your values

# Server
NODE_ENV=production
PORT=5000

# Database
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/database?retryWrites=true&w=majority

# JWT
JWT_SECRET=your-super-secret-jwt-key-minimum-32-characters-long
JWT_EXPIRE=365d
JWT_REFRESH_SECRET=your-super-secret-refresh-key-minimum-32-characters-long
JWT_REFRESH_EXPIRE=3650d

# Email (Gmail)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=eft.gretech@gmail.com
EMAIL_PASS=smvevprdsqqoyqjd
EMAIL_FROM=eft.gretech@gmail.com
ADMIN_EMAIL=eft.gretech@gmail.com

# SMS API (Optional - for SMS password reset)
# Register at https://smsapi.vn or use another SMS provider
SMS_USERNAME=your-sms-username
SMS_PASSWORD=your-sms-password
SMS_SENDER_NAME=EFT
SMS_API_KEY=your-sms-api-key

# Frontend
FRONTEND_URL=https://your-frontend-domain.vercel.app
